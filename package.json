    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.0.0",
    "lint-staged": "^13.0.0",
    "postcss": "^8.4.24",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.1.3",
    "vitest": "^3.0.0"
